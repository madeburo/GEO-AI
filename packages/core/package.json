{
  "name": "geo-ai-core",
  "version": "0.2.3",
  "description": "Zero-dependency TypeScript engine for AI Search Optimization (GEO) — generates llms.txt, manages AI crawlers, SEO signals, caching and more",
  "license": "MIT",
  "homepage": "https://www.geoai.run",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeburo/GEO-AI.git",
    "directory": "packages/core"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./ai": {
      "types": "./dist/ai/index.d.ts",
      "import": "./dist/ai/index.mjs",
      "require": "./dist/ai/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "keywords": [
    "geo",
    "llms",
    "llms-txt",
    "llms.txt",
    "ai",
    "ai-search-optimization",
    "geoai",
    "chatgpt",
    "claude",
    "grok",
    "perplexity",
    "robots-txt",
    "crawler",
    "bot",
    "ai-search",
    "content-optimization",
    "structured-data",
    "json-ld",
    "schema-org",
    "nodejs",
    "node.js",
    "typescript"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
