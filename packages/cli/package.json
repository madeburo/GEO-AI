{
  "name": "geo-ai-cli",
  "version": "0.1.1",
  "description": "CLI for generating and validating llms.txt / llms-full.txt — AI Search Optimization (GEO) for any Node.js project",
  "license": "GPL-2.0",
  "homepage": "https://www.geoai.run",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/madeburo/GEO-AI.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "geo-ai": "dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "geo",
    "llms",
    "llms-txt",
    "llms.txt",
    "ai",
    "ai-search-optimization",
    "geoai",
    "cli",
    "chatgpt",
    "claude",
    "grok",
    "perplexity",
    "robots-txt",
    "crawler",
    "ai-search",
    "content-optimization",
    "nodejs",
    "node.js",
    "typescript"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "geo-ai-core": "^0.2.2"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
